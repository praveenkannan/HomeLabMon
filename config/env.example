# HomeLabMon non-secret defaults only.
# Keep real secrets outside this repository.
# Recommended runtime secret sources:
# - /etc/homelabmon/monitor.env
# - /run/secrets/homelabmon_ai_api_key

HOMELABMON_ENV=development
HOMELABMON_CONFIG_PATH=./config/devices.local.json
HOMELABMON_RELEASE_CHANNEL=stable
HOMELABMON_INSTANCE_NAME=homelab-dev
HOMELABMON_TIMEZONE=America/Los_Angeles
HOMELABMON_SECRET_ENV_FILE=/etc/homelabmon/monitor.env
HOMELABMON_AI_API_KEY_FILE=/run/secrets/homelabmon_ai_api_key
AI_API_KEY=__INJECT_AT_RUNTIME_ONLY__
