{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelabmon.local/error.schema.v1.json",
  "title": "HomeLabMon Error v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "error"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "const": "1.0"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "status",
        "request_id",
        "retryable",
        "details"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 3,
          "maxLength": 64
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "status": {
          "type": "integer",
          "minimum": 400,
          "maximum": 599
        },
        "request_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "maxProperties": 16
        },
        "docs_url": {
          "type": "string",
          "format": "uri"
        },
        "retry_after_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
